# Render will give you this automatically if you add a PostgreSQL
# instance and link it — or paste your own connection string here.
DATABASE_URL=postgresql://user:password@host:5432/dbname

# Comma-separated list of the frontend domains allowed to call this API.
# Example: https://yerevanwebstudio.com,https://www.yerevanwebstudio.com
FRONTEND_ORIGIN=http://localhost:5173

# Secret key you choose yourself — used to view /admin and the
# GET /api/submissions endpoint. Pick something long and random.
ADMIN_KEY=change-me-to-something-long-and-random

# Render sets this automatically, only needed for local dev
PORT=4000
